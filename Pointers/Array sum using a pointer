#include <stdio.h>

int arraysum(int *a, int size)
{
    int sum = 0, i;

    for (i = 0; i < size; i++)
    {
        sum += *(a + i);
    }

    return sum;
}

int main()
{
    int arr[] = {1, 2, 3, 4, 5};
    int size = sizeof(arr) / sizeof(arr[0]);

    printf("Sum = %d", arraysum(arr, size));

    return 0;
}
